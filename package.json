{
  "name": "grove",
  "productName": "Grove",
  "version": "0.4.1",
  "description": "Grove — a desktop control room for running multiple coding-agent sessions per git worktree across projects",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "postinstall": "node -e \"try{const fs=require('fs'),p=require('path'),d=p.join('node_modules','node-pty','prebuilds');for(const a of fs.readdirSync(d)){const f=p.join(d,a,'spawn-helper');if(fs.existsSync(f))fs.chmodSync(f,0o755)}}catch(e){}\"",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest",
    "e2e": "electron-vite build && node e2e/smoke.mjs",
    "dist": "npm run build && electron-builder --mac",
    "dist:dir": "npm run build && electron-builder --mac --dir"
  },
  "build": {
    "appId": "com.yanghung.grove",
    "productName": "Grove",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "!**/.vscode/*",
      "!src/**",
      "!e2e/**",
      "!.claude/**",
      "!build/**",
      "!{electron.vite.config.ts,tsconfig.json}",
      "!{.eslintrc,.eslintignore,.prettierrc,.prettierignore,README.md}",
      "!**/*.{test,spec}.*"
    ],
    "asarUnpack": [
      "**/node_modules/node-pty/**"
    ],
    "npmRebuild": false,
    "afterSign": "build/adhoc-sign.cjs",
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.png",
      "identity": null
    }
  },
  "keywords": [
    "electron",
    "pty",
    "worktree",
    "coding-agent",
    "terminal"
  ],
  "license": "MIT",
  "dependencies": {
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "dompurify": "^3.4.9",
    "marked": "^18.0.5",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.0.0",
    "electron-builder": "^26.15.2",
    "electron-vite": "^2.3.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
